   "source": [
    "# to find the Fibonacci series upto the nth term.\n",
    "\n",
    "num=int(input(\"enter no\"))\n",
    "n1,n2=0,1\n",
    "print(\"fib series:\",n1,n2,end=\" \")\n",
    "for i in range(2,num):\n",
    "    n3=n1+n2\n",
    "    n1=n2\n",
    "    n2=n3\n",
    "    print(n3,end=\" \")\n",
    "\n",
    "print()"
   ]
